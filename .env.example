# PulseNet Frontend — Environment Variables

# ── Local Development ─────────────────────────────────────────
# Leave VITE_API_URL blank in development.
# Vite proxy (vite.config.js) forwards /api/* to localhost:5000 automatically.
VITE_API_URL=

# ── Production (Vercel) ───────────────────────────────────────
# Set this to your Render backend URL in Vercel's Environment Variables dashboard:
# VITE_API_URL=https://pulsenet-api.onrender.com
